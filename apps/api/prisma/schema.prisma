generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Character {
  id          Int    @id @default(autoincrement())
  image       String
  name        String
  status      String
  gender      String
  description String

  @@index([status])
  @@index([gender])
  @@index([name])
}

